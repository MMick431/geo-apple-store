{
  "version": 2,
  "buildCommand": "npm install",
  "outputDirectory": "public",
  "functions": {
    "api/**/*.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/gestion-prive-x7k2m9", "dest": "/public/admin-secure.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
